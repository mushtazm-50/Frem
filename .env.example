# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Strava OAuth (frontend)
VITE_STRAVA_CLIENT_ID=your-strava-client-id
VITE_STRAVA_REDIRECT_URI=https://your-app.vercel.app/strava/callback

# Supabase Edge Function environment variables (set via Supabase dashboard):
# STRAVA_CLIENT_ID=your-strava-client-id
# STRAVA_CLIENT_SECRET=your-strava-client-secret
# STRAVA_VERIFY_TOKEN=your-random-verify-token
# CLAUDE_API_KEY=your-anthropic-api-key
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# TELEGRAM_CHAT_ID=your-telegram-chat-id
# FREM_BASE_URL=https://your-app.vercel.app
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
